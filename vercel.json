{
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "main.py"
    },
    {
      "src": "/style.css",
      "dest": "public/style.css"
    },
    {
      "src": "/script.js",
      "dest": "public/script.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/index.html"
    }
  ]
}
