# LLM Configuration
# LLM_PROVIDER can be 'openai', 'gemini', or 'groq'
LLM_PROVIDER=gemini

# API Key for the selected provider
API_KEY=your_api_key_here

# Model to use (optional, will use default if not provided)
# OpenAI Default: gpt-4o-mini
# Gemini Default: gemini-1.5-flash
# Groq Default: llama3-8b-8192
MODEL=gemini-1.5-pro
