# Git ignore rules for AI Chat Application

# ── Secrets & environment ──────────────────────────────────────────────
.env
.streamlit/secrets.toml

# ── SQLite database (local only) ───────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ── Python artifacts ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── IDE / OS files ─────────────────────────────────────────────────────
.idea/
.vscode/
*.DS_Store
Thumbs.db
